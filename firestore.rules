rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProposal(data) {
      return data.userId == request.auth.uid
        && data.clientName is string && data.clientName.size() <= 200
        && data.projectTitle is string && data.projectTitle.size() <= 300
        && data.content is string && data.content.size() <= 50000
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidTemplate(data) {
      return data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /proposals/{proposalId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(proposalId) && isValidProposal(incoming());
      allow update: if isOwner(existing().userId) && isValidProposal(incoming()) 
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    match /templates/{templateId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(templateId) && isValidTemplate(incoming());
      allow update: if isOwner(existing().userId) && isValidTemplate(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }
  }
}
