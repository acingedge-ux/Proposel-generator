{
  "entities": {
    "Proposal": {
      "title": "Proposal",
      "description": "Store clinical proposals generated by AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "clientName": { "type": "string" },
        "companyName": { "type": "string" },
        "projectTitle": { "type": "string" },
        "description": { "type": "string" },
        "scope": { "type": "string" },
        "timeline": { "type": "string" },
        "budget": { "type": "string" },
        "notes": { "type": "string" },
        "tone": { "type": "string", "enum": ["Professional", "Friendly", "Persuasive", "Aggressive"] },
        "content": { "type": "string", "description": "Markdown content" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "clientName", "projectTitle", "content", "createdAt", "updatedAt"]
    },
    "Template": {
      "title": "Template",
      "description": "Reusable form inputs for proposals",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string", "description": "Template name" },
        "clientName": { "type": "string" },
        "companyName": { "type": "string" },
        "projectTitle": { "type": "string" },
        "description": { "type": "string" },
        "scope": { "type": "string" },
        "timeline": { "type": "string" },
        "budget": { "type": "string" },
        "notes": { "type": "string" },
        "tone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/proposals/{proposalId}": {
      "schema": "Proposal",
      "description": "Collection of generated proposals"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Collection of saved form templates"
    }
  }
}
